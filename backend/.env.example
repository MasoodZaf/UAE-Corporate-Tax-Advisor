# =============================================================================
# TaxMaster AI - Environment Configuration
# UAE Corporate Tax AI Compliance System
# =============================================================================

# Environment
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database Configuration
# PostgreSQL (Primary Database)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=taxmaster_ai
POSTGRES_USER=taxmaster_app
POSTGRES_PASSWORD=TaxM@ster2025!
POSTGRES_SSL=false
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10

# MongoDB (Document Storage)
MONGODB_URI=mongodb://localhost:27017/taxmaster_ai_docs
MONGODB_OPTIONS=retryWrites=true&w=majority

# Redis (Cache & Sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# Encryption
ENCRYPTION_KEY=your_32_character_encryption_key_here
HASH_ROUNDS=12

# File Storage
STORAGE_TYPE=local
# For AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=me-south-1
AWS_S3_BUCKET=taxmaster-ai-documents

# For local storage
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,heic

# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=noreply@taxmaster.ai
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=TaxMaster AI <noreply@taxmaster.ai>

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+971XXXXXXXXX

# UAE Government Integrations
# EmaraTax API
EMIRATAX_BASE_URL=https://tax.gov.ae/api
EMIRATAX_CLIENT_ID=your_emiratax_client_id
EMIRATAX_CLIENT_SECRET=your_emiratax_client_secret

# UAE Pass Integration
UAE_PASS_CLIENT_ID=your_uae_pass_client_id
UAE_PASS_CLIENT_SECRET=your_uae_pass_client_secret
UAE_PASS_REDIRECT_URI=https://api.taxmaster.ai/auth/uae-pass/callback

# Banking APIs
# Emirates NBD
ENBD_API_KEY=your_enbd_api_key
ENBD_API_SECRET=your_enbd_api_secret
ENBD_BASE_URL=https://api.emiratesnbd.com

# ADCB Open Banking
ADCB_API_KEY=your_adcb_api_key
ADCB_API_SECRET=your_adcb_api_secret
ADCB_BASE_URL=https://api.adcb.com

# AI/ML Services
# OCR Configuration
OCR_SERVICE=tesseract
OCR_API_KEY=your_ocr_api_key
OCR_CONFIDENCE_THRESHOLD=0.8

# ML Model Endpoints
ML_MODEL_BASE_URL=http://localhost:8000
ML_CLASSIFICATION_ENDPOINT=/classify-expense
ML_EXTRACTION_ENDPOINT=/extract-data
ML_OPTIMIZATION_ENDPOINT=/optimize-tax

# Monitoring & Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# APM & Monitoring
DATADOG_API_KEY=your_datadog_api_key
NEW_RELIC_LICENSE_KEY=your_new_relic_key
SENTRY_DSN=your_sentry_dsn

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL=true

# CORS Configuration
CORS_ORIGIN=http://localhost:3001,https://app.taxmaster.ai
CORS_CREDENTIALS=true

# Security
HELMET_ENABLED=true
COMPRESSION_ENABLED=true
TRUST_PROXY=1

# Message Queue (Kafka)
KAFKA_CLIENT_ID=taxmaster-ai
KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=taxmaster-ai-consumers

# Bull Queue (Redis-based)
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6379
BULL_REDIS_PASSWORD=

# Cron Jobs
ENABLE_CRON_JOBS=true
COMPLIANCE_CHECK_SCHEDULE=0 9 * * *
BACKUP_SCHEDULE=0 2 * * *

# Business Configuration
DEFAULT_TAX_RATE=0.09
SMALL_BUSINESS_THRESHOLD=375000
DMTT_THRESHOLD=750000000
VAT_THRESHOLD=187500
DOCUMENT_RETENTION_YEARS=7

# Subscription Plans
STARTER_PLAN_LIMIT=5000000
PROFESSIONAL_PLAN_LIMIT=25000000
ENTERPRISE_PLAN_LIMIT=0

# Feature Flags
ENABLE_AI_CLASSIFICATION=true
ENABLE_BANK_INTEGRATION=true
ENABLE_FTA_INTEGRATION=false
ENABLE_UAE_PASS=true
ENABLE_DOCUMENT_OCR=true
ENABLE_TAX_OPTIMIZATION=true

# Development/Testing
MOCK_EXTERNAL_APIS=true
SEED_DATABASE=true
DEBUG_SQL=false
ENABLE_SWAGGER=true